# Railway will inject DATABASE_URL automatically when Postgres is linked.
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Facebook Page (Graph API) — copy from ~/.facebook_tokens on the Mac
FB_PAGE_ID=
FB_PAGE_TOKEN=

# Set to 1 on first deploy to verify selection without sending real posts.
AUTOPOSTER_DRY_RUN=1

# Cooldown between repeat-listing posts on the same channel.
LISTING_COOLDOWN_DAYS=7

# Path (from services/autoposter) to the listings TS file in the repo root.
# Default works in the Railway monorepo layout.
LISTINGS_TS_PATH=../../lib/listings.ts
