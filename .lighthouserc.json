{
  "ci": {
    "collect": {
      "startServerCommand": "npm run start",
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/cash-offer",
        "http://localhost:3000/blog/nashville-real-estate-market-2025",
        "http://localhost:3000/sell/franklin-tn",
        "http://localhost:3000/buy/franklin-tn"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--no-sandbox --disable-dev-shm-usage --headless=new"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.85 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.9 }],

        "largest-contentful-paint": ["warn", { "maxNumericValue": 2500 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 300 }],
        "speed-index": ["warn", { "maxNumericValue": 3500 }],

        "meta-description": "error",
        "meta-viewport": "error",
        "structured-data": "warn",
        "is-on-https": "error",
        "document-title": "error",
        "hreflang": "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
